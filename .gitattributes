# Auto detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts
*.sh text eol=lf

# Force CRLF for Windows batch files
*.cmd text eol=crlf
*.bat text eol=crlf

# Treat lockfiles as generated (collapse diffs in reviews)
package-lock.json -diff
yarn.lock -diff
pnpm-lock.yaml -diff
